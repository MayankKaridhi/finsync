# FinSync configuration. Copy to `.env` and adjust.

# Port FinSync's gateway listens on.
PORT=4000

# Downstream accounting system endpoint (the mock server by default).
ACCOUNTING_API_URL=http://localhost:4100/api/v1/journal-entries

# Shared secret for verifying inbound webhook HMAC-SHA256 signatures.
WEBHOOK_SECRET=finsync_dev_secret_change_me

# Set to "false" to disable signature enforcement (handy for manual curl tests).
ENFORCE_SIGNATURE=true

# Outbound connector resilience.
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_MS=200
HTTP_TIMEOUT_MS=5000

# Logging: error | warn | info | debug
LOG_LEVEL=info

# Where exhausted events are dead-lettered.
DEAD_LETTER_PATH=logs/dead-letter.log

# --- Mock accounting server knobs (used by `npm run mock`) ---
MOCK_PORT=4100
# Make the first N calls fail with 503 to demonstrate retry/backoff recovery.
FAIL_TIMES=0
